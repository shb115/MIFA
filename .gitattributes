# TCHES 2026 MIFA artifact — line-ending policy.
#
# reproduce.sh has a #!/usr/bin/env bash shebang and MUST stay LF-only;
# Git for Windows' default core.autocrlf=true would otherwise rewrite
# it to CRLF on checkout and break the bash shebang parser
# ("/usr/bin/env: 'bash\r': No such file or directory").
#
# We also pin every committed text file to LF so that the reviewer's
# `diff -r reproduce_output/ <cipher>/Results/` workflow is
# byte-stable across OSes (macOS, Linux, WSL, Windows).

# Default: treat as text, check in as LF.
* text=auto eol=lf

# Explicit overrides for files where LF is critical.
*.sh        text eol=lf
*.py        text eol=lf
*.c         text eol=lf
*.h         text eol=lf
*.md        text eol=lf
Makefile    text eol=lf
*.txt       text eol=lf

# Binary artefacts that must not be munged.
*.pkl       binary
